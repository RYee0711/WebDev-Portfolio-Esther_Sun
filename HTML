<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Study Focus Music 📚</title>
    <link rel="stylesheet" href="styles/style.css">
</head>
<body>

    <div class="container">
        <h1>Study Focus Player</h1>
        <p>Relaxing music for your study session</p>

        <div class="music-list">
            <button class="music-btn" data-audio="lofi">🎧 Lofi Study Beats</button>
            <button class="music-btn" data-audio="rain">🌧️ Rain White Noise</button>
            <button class="music-btn" data-audio="piano">🎹 Soft Piano</button>
        </div>

        <div class="controls">
            <button id="playPauseBtn">▶️ Play</button>
            <input type="range" id="volume" min="0" max="1" step="0.1" value="0.5">
        </div>
    </div>

    <!-- 免费在线音频资源，无需自己下载文件 -->
    <audio id="lofi" loop>
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
    
    <audio id="rain" loop>
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3" type="audio/mpeg">
    
    <audio id="piano" loop>
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3" type="audio/mpeg">
    

    <script src="scripts/main.js"></script>
</body>
</html>
